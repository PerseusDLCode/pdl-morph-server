<!doctype html>
<html>
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{% block title %}{% endblock %}</title>
{# <link href="{{ url_for('static', filename='css/output.css') }}" rel="stylesheet" type="text/css" /> #}
        <link href="https://cdn.jsdelivr.net/npm/daisyui@5" rel="stylesheet" type="text/css" />
        <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    </head>
    <body class="bg-neutral-50 p-4 min-h-screen" data-theme="wireframe">
        {% block header %}{% endblock %}
        <nav
            class="bg-neutral-500 text-neutral-200 font-bold flex justify-between mb-4 px-8 py-2 text-sm"
        >
            <a href="#" class="hover:text-base-content">Home</a>
            <a href="#" class="hover:text-base-content">Collections/Texts</a>
            <a href="https://catalog.perseus.org" class="hover:text-base-content">Perseus Catalog</a>
            <a href="#" class="hover:text-base-content">Research</a>
            <a href="#" class="hover:text-base-content">Grants</a>
            <a href="#" class="hover:text-base-content">Open Source</a>
            <a href="#" class="hover:text-base-content">About</a>
            <a href="#" class="hover:text-base-content">Help</a>
        </nav>
        {% block content %}
        {% endblock %}
        {% block scripts %}{% endblock %}
    </body>
</html>
